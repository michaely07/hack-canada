# Environment Variables (example)

# Database
# Railway auto-injects DATABASE_URL when you provision PostgreSQL.
DATABASE_URL=postgresql://dev:dev@localhost:5433/statutelens

# LLM
GEMINI_API_KEY=

# Voice
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Embeddings (local, no key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# App
CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=info
